# Client (bundled into the app — EXPO_PUBLIC_* only, never secrets)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-publishable-anon-key

# Server-side only — used by scripts and Supabase Edge Functions.
# NEVER reference these from app/ or lib/ code; they must not reach the RN bundle.
SCRYDEX_API_KEY=
SCRYDEX_TEAM_ID=
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
