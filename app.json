{
  "expo": {
    "name": "Vault",
    "slug": "Vault",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "vault",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.devinpadron.vault",
      "usesAppleSignIn": true,
      "associatedDomains": [
        "applinks:vault.app"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0A0A0C",
          "dark": {
            "backgroundColor": "#0A0A0C"
          }
        }
      ],
      "expo-secure-store",
      "expo-sqlite",
      [
        "expo-camera",
        {
          "cameraPermission": "Vault uses the camera to scan Pokémon cards."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Vault uses your photo library to set your profile picture.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ],
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "color": "#FFD700"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "17e11c01-aafd-4973-9f2b-f16efd7474c4"
      }
    },
    "owner": "devinpadron",
    "android": {
      "package": "com.devinpadron.vault"
    }
  }
}
