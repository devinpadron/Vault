    "seed:history": "node seed-history.mjs",
    "seed:history:shallow": "node seed-history.mjs --days 30 --batch 20"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.47.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
